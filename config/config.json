{
  "system_config": {
    "version": "2.0.0",
    "admin_channel": -1002495720174
  },
  "destinations": {
    "T1": {
      "platform": "telegram",
      "channel_id": -1002458855204
    },
    "T2": {
      "platform": "telegram",
      "channel_id": -1001648497395
    },
    "TW1": {
      "platform": "twitter",
      "account_id": "twitter_t1"
    }
  },
  "message_types": {
    "trade_setup": {
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "\ud83d\udcc9 {symbol} ({asset_class})\\n\ud83d\udd0e Direction: {side}\\n\u26a1\ufe0f Entry: {entry}\\n\ud83c\udfaf Target: {target}\\n\ud83d\uded1 Stop: {stop_loss}"
      }
    }
  },
  "command_processing": {
    "/update": {
      "command_mapping": {
        "CLOSED": {
          "type": "trade_close_specific",
          "update_type": "CLOSED"
        },
        "PARTIAL": {
          "type": "partial_close_specific",
          "update_type": "PARTIAL"
        },
        "CLOSEHALF": {
          "type": "close_half_specific",
          "update_type": "CLOSEHALF"
        },
        "TARGET": {
          "type": "target_hit_specific",
          "update_type": "TARGET"
        },
        "STOPPED": {
          "type": "stopped_out_specific",
          "update_type": "STOPPED"
        },
        "TRAIL": {
          "type": "trail_update_specific",
          "update_type": "TRAIL"
        },
        "BREAKEVEN": {
          "type": "breakeven_specific",
          "update_type": "BREAKEVEN"
        }
      }
    }
  },
  "ocr_processing": {
    "model": "gemini-2.5-flash",
    "timeout": 30,
    "prompt": "Analyze this TradingView chart",
    "key_management": {
      "max_retries": 3
    },
    "output_mapping": {
      "symbol": "symbol",
      "asset_class": "asset_class",
      "side": "side",
      "entry": "entry",
      "target": "target",
      "stop_loss": "stop_loss"
    }
  },
  "trade_ledger": {
    "enabled": true,
    "auto_create": true,
    "calculate_locked_profit": true,
    "cleanup_days": 90
  },
  "fifo_settings": {
    "enabled": true,
    "tree_visualization": true,
    "max_line_length": 35,
    "show_booked_pnl": true,
    "show_remaining_position": true,
    "tree_prefixes": {
      "branch": "\u251c\u2500",
      "end": "\u2514\u2500"
    }
  },
  "leverage_settings": {
    "enabled": true,
    "multipliers": {
      "FOREX": 50,
      "CRYPTO": 20,
      "METAL": 50,
      "INDEX": 1,
      "STOCK": 1
    }
  },
  "pyramid_settings": {
    "max_pyramids_per_trade": 5
  },
  "price_formatting": {
    "formats_by_asset": {
      "FOREX": {
        "decimal_places": 5
      },
      "CRYPTO": {
        "decimal_places": 2
      },
      "INDEX": {
        "decimal_places": 2
      }
    }
  }
