{
  "system_config": {
    "version": "1.0.0",
    "bot_name": "TradingBot"
  },
  "message_types": {
    "trade_setup": {
      "description": "Trade setup from OCR",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "📉 {symbol} ({asset_class})\n🔎 Direction: {side}\n⚡️ Entry: {entry}\n🎯 Target: {target}\n🛑 Stop: {stop_loss}",
        "twitter": "📉 {symbol} ({asset_class})\nDirection: {side}\nEntry: {entry}\nTarget: {target}\nStop: {stop_loss}"
      },
      "create_trade_ledger": true
    },
    "partial_close_specific": {
      "description": "Partial close",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "🔹 PARTIAL CLOSE ({percentage}%)\n{tree_lines}\n\n• Booked: {pnl}",
        "twitter": "🔹 PARTIAL ({percentage}%)\n{tree_lines}\nBooked: {pnl}"
      },
      "fifo_format": {
        "enabled": true,
        "use_tree": true
      }
    },
    "trade_close_specific": {
      "description": "Trade closed",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "✅ TRADE CLOSED\n• PnL: {pnl}",
        "twitter": "✅ CLOSED\nPnL: {pnl}"
      }
    },
    "trail_update_specific": {
      "description": "Trailing stop",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "🔁 TRAILING STOP\n• New Stop: {new_stop}",
        "twitter": "🔁 TRAILING\nStop: {new_stop}"
      }
    }
  },
  "command_processing": {
    "/update": {
      "command_mapping": {
        "TRAIL": {
          "type": "trail_update_specific",
          "requires_price": true,
          "update_type": "TRAIL"
        },
        "CLOSED": {
          "type": "trade_close_specific",
          "requires_price": true,
          "update_type": "CLOSED"
        },
        "CLOSE": {
          "type": "trade_close_specific",
          "requires_price": true,
          "update_type": "CLOSED"
        },
        "PARTIAL": {
          "type": "partial_close_specific",
          "requires_price": true,
          "percentage": "25",
          "update_type": "PARTIAL"
        },
        "CLOSEHALF": {
          "type": "partial_close_specific",
          "requires_price": true,
          "percentage": "50",
          "update_type": "CLOSEHALF"
        }
      },
      "parse_patterns": [
        {
          "pattern": "trail\s+(\d+\.?\d*)",
          "command": "TRAIL",
          "extract": ["price"]
        },
        {
          "pattern": "closed\s+(\d+\.?\d*)",
          "command": "CLOSED",
          "extract": ["price"]
        },
        {
          "pattern": "close\s+(\d+\.?\d*)",
          "command": "CLOSE",
          "extract": ["price"]
        },
        {
          "pattern": "partial\s+(\d+\.?\d*)",
          "command": "PARTIAL",
          "extract": ["price"]
        },
        {
          "pattern": "closehalf\s+(\d+\.?\d*)",
          "command": "CLOSEHALF",
          "extract": ["price"]
        }
      ]
    }
  }
}
