{
  "system_config": {
    "version": "1.0.0",
    "bot_name": "TradingBot"
  },
  "execution_map": {
    "trade_setup": "create_trade",
    "partial_close_specific": "partial_close",
    "trade_close_specific": "full_close",
    "trail_update_specific": "update_stop",
    "pyramid_add": "pyramid_add",
    "cancel_trade": "cancel_trade",
    "target_hit": "target_hit",
    "stopped_out": "stopped_out",
    "breakeven_trigger": "breakeven_trigger",
    "note_add": "note_add"
  },
  "message_types": {
    "trade_setup": {
      "description": "Trade setup from OCR",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "📉 {symbol} ({asset_class})\n🔎 Direction: {side}\n⚡️ Entry: {entry}\n🎯 Target: {target}\n🛑 Stop: {stop_loss}",
        "twitter": "📉 {symbol} ({asset_class})\nDirection: {side}\nEntry: {entry}\nTarget: {target}\nStop: {stop_loss}"
      },
      "create_trade_ledger": true
    },
    "partial_close_specific": {
      "description": "Partial close",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "🔹 PARTIAL CLOSE ({percentage}%)\n{tree_lines}\n\n• Booked: {pnl}",
        "twitter": "🔹 PARTIAL ({percentage}%)\n{tree_lines}\nBooked: {pnl}"
      },
      "fifo_format": {
        "enabled": true,
        "use_tree": true
      }
    },
    "trade_close_specific": {
      "description": "Trade closed",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "✅ TRADE CLOSED\n• PnL: {pnl}",
        "twitter": "✅ CLOSED\nPnL: {pnl}"
      }
    },
    "trail_update_specific": {
      "description": "Trailing stop",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "🔁 TRAILING STOP\n• New Stop: {new_stop}",
        "twitter": "🔁 TRAILING\nStop: {new_stop}"
      }
    },
    "target_hit": {
      "description": "Target hit",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "🎯 TARGET HIT\n• PnL: {pnl}\n• Remaining: {remaining}%",
        "twitter": "🎯 TARGET HIT\nPnL: {pnl}"
      }
    },
    "stopped_out": {
      "description": "Stopped out",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "🛑 STOPPED OUT\n• PnL: {pnl}",
        "twitter": "🛑 STOPPED OUT\nPnL: {pnl}"
      }
    },
    "breakeven_trigger": {
      "description": "Breakeven triggered",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "⚖️ BREAKEVEN\n• Stop moved to entry",
        "twitter": "⚖️ BREAKEVEN\nStop moved to entry"
      }
    },
    "cancelled": {
      "description": "Trade cancelled",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "❌ CANCELLED\n• Reason: {reason}",
        "twitter": "❌ CANCELLED\nReason: {reason}"
      }
    },
    "pyramid_add": {
      "description": "Pyramid entry added",
      "platform_rules": {
        "telegram": true,
        "twitter": true
      },
      "formatting": {
        "telegram": "📈 PYRAMID ADD\n• Entry: {entry_price}\n• Size: {size}",
        "twitter": "📈 PYRAMID ADD\nEntry: {entry_price}"
      }
    },
    "note_add": {
      "description": "Note added to trade",
      "platform_rules": {
        "telegram": true,
        "twitter": false
      },
      "formatting": {
        "telegram": "📝 NOTE\n{note_text}",
        "twitter": ""
      }
    }
  },
  "command_processing": {
    "/update": {
      "command_mapping": {
        "TRAIL": {
          "type": "trail_update_specific",
          "requires_price": true,
          "update_type": "TRAIL"
        },
        "CLOSED": {
          "type": "trade_close_specific",
          "requires_price": true,
          "update_type": "CLOSED"
        },
        "CLOSE": {
          "type": "trade_close_specific",
          "requires_price": true,
          "update_type": "CLOSED"
        },
        "PARTIAL": {
          "type": "partial_close_specific",
          "requires_price": true,
          "percentage": "25",
          "update_type": "PARTIAL"
        },
        "CLOSEHALF": {
          "type": "partial_close_specific",
          "requires_price": true,
          "percentage": "50",
          "update_type": "CLOSEHALF"
        },
        "PYRAMID": {
          "type": "pyramid_add",
          "requires_price": true,
          "update_type": "PYRAMID"
        },
        "CANCEL": {
          "type": "cancelled",
          "requires_price": false,
          "update_type": "CANCEL"
        },
        "NOTE": {
          "type": "note_add",
          "requires_price": false,
          "update_type": "NOTE"
        }
      },
      "parse_patterns": [
        {
          "pattern": "trail\s+(\d+\.?\d*)",
          "command": "TRAIL",
          "extract": ["price"]
        },
        {
          "pattern": "closed\s+(\d+\.?\d*)",
          "command": "CLOSED",
          "extract": ["price"]
        },
        {
          "pattern": "close\s+(\d+\.?\d*)",
          "command": "CLOSE",
          "extract": ["price"]
        },
        {
          "pattern": "partial\s+(\d+\.?\d*)",
          "command": "PARTIAL",
          "extract": ["price"]
        },
        {
          "pattern": "closehalf\s+(\d+\.?\d*)",
          "command": "CLOSEHALF",
          "extract": ["price"]
        },
        {
          "pattern": "pyramid\s+(\d+\.?\d*)",
          "command": "PYRAMID",
          "extract": ["price"]
        },
        {
          "pattern": "cancel\s*(.*)",
          "command": "CANCEL",
          "extract": ["reason"]
        },
        {
          "pattern": "note\s+(.*)",
          "command": "NOTE",
          "extract": ["note_text"]
        }
      ]
    }
  }
}