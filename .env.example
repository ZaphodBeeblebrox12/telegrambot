# Trading Bot Environment Configuration

# Required: Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database Connection
# MySQL: mysql+pymysql://user:password@host/database
# PostgreSQL: postgresql+psycopg2://user:password@host/database
DATABASE_URL=mysql+pymysql://trading_user:trading_pass@localhost/trading_db

# Optional: Config file path
CONFIG_PATH=config/config.json

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
