# Trading Bot Environment Variables

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Gemini OCR (supports multiple keys for rotation)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_1=your_backup_key_1
GEMINI_API_KEY_2=your_backup_key_2

# Twitter (TW1)
TW1_API_KEY=your_twitter_api_key
TW1_API_SECRET=your_twitter_api_secret
TW1_ACCESS_TOKEN=your_twitter_access_token
TW1_ACCESS_SECRET=your_twitter_access_secret
TW1_BEARER_TOKEN=your_twitter_bearer_token

# Twitter (TW2)
TW2_API_KEY=your_twitter_api_key_2
TW2_API_SECRET=your_twitter_api_secret_2
TW2_ACCESS_TOKEN=your_twitter_access_token_2
TW2_ACCESS_SECRET=your_twitter_access_secret_2
TW2_BEARER_TOKEN=your_twitter_bearer_token_2
